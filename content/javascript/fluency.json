  {
    "id": "js.map.counts",
    "track": "javascript",
    "group": "Map & Set",
    "concept": "frequency Map of counts",
    "kind": "write",
    "prompt": "Write `counts(arr)` that returns a Map from each element to how many times it appears.",
    "starter": "function counts(arr) {\n  // your code here\n}",
    "solution": "function counts(arr) {\n  const m = new Map();\n  for (const x of arr) m.set(x, (m.get(x) || 0) + 1);\n  return m;\n}",
    "tests": "const c = counts(['a', 'b', 'a', 'c', 'a', 'b']);\nif (!(c instanceof Map)) throw new Error('should return a Map');\nif (c.get('a') !== 3 || c.get('b') !== 2 || c.get('c') !== 1) throw new Error('wrong counts: ' + JSON.stringify([...c]));\nif (c.size !== 3) throw new Error('expected 3 distinct keys');",
    "prereqs": ["js.set.dedupe"]
  }
